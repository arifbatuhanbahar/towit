{
  "name": "towit",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c blue,cyan \"npm run dev -w apps/server\" \"npm run dev -w apps/web\"",
    "build": "npm run build -w apps/server && npm run build -w apps/web",
    "typecheck": "npm run typecheck:server && npm run typecheck:web",
    "typecheck:server": "tsc --noEmit -p apps/server",
    "typecheck:web": "tsc --noEmit -p apps/web",
    "test": "npm run test -w apps/server",
    "test:server": "npm run test -w apps/server",
    "db:generate": "npm run db:generate -w apps/server",
    "db:migrate": "npm run db:migrate -w apps/server",
    "db:push": "npm run db:push -w apps/server",
    "docker:up": "docker compose up -d",
    "clean": "rimraf apps/server/dist apps/web/dist"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "rimraf": "^6.0.1"
  }
}
