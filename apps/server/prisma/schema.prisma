generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  customer
  operator
}

enum JobStatus {
  payment_pending
  open
  accepted
  en_route
  completed
  rejected
  cancelled
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role
  createdAt    DateTime @default(now())

  operatorProfile OperatorProfile?
  customerJobs    Job[]           @relation("CustomerJobs")
  refreshTokens   RefreshToken[]
}

model OperatorProfile {
  id               String  @id @default(cuid())
  userId           String  @unique
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName     String
  vehicleInfo      String
  serviceCenterLat Float
  serviceCenterLng Float
  serviceRadiusKm  Float   @default(50)
  isActive         Boolean @default(true)

  tariff  Tariff?
  jobs    Job[]    @relation("OperatorJobs")
  reviews Review[] @relation("OperatorReviews")
}

model Tariff {
  id         String            @id @default(cuid())
  operatorId String            @unique
  operator   OperatorProfile   @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  baseFee    Decimal           @db.Decimal(12, 2)
  perKmFee   Decimal           @db.Decimal(12, 4)
}

model Job {
  id            String    @id @default(cuid())
  customerId    String
  customer      User      @relation("CustomerJobs", fields: [customerId], references: [id], onDelete: Cascade)
  operatorId    String
  operator      OperatorProfile @relation("OperatorJobs", fields: [operatorId], references: [id], onDelete: Restrict)
  cityCode      String
  pickupLat     Float
  pickupLng     Float
  destLat       Float
  destLng       Float
  distanceKm    Float
  priceSnapshot Decimal   @db.Decimal(12, 2)
  status        JobStatus
  operatorLat   Float?
  operatorLng   Float?
  operatorLocAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt

  review Review?
}

model Review {
  id         String   @id @default(cuid())
  jobId      String   @unique
  job        Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  operatorId String
  operator   OperatorProfile @relation("OperatorReviews", fields: [operatorId], references: [id], onDelete: Cascade)
  customerId String
  rating     Int      // 1..5
  comment    String?  @db.VarChar(500)
  createdAt  DateTime @default(now())

  @@index([operatorId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}
